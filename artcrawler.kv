#:kivy 2.3.0

<RootManager>:
    HomeScreen:
        name: "home"
    LogScreen:
        name: "logs"

<HomeScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(10)
        spacing: dp(10)

        Label:
            text: root.status_text
            font_size: "18sp"
            size_hint_y: None
            height: dp(40)

        Label:
            text: root.db_stats_text
            font_size: "16sp"
            size_hint_y: None
            height: dp(40)

        Label:
            text: root.crawler_status_text
            font_size: "16sp"
            size_hint_y: None
            height: dp(40)

        Label:
            text: root.indexer_status_text
            font_size: "16sp"
            size_hint_y: None
            height: dp(40)

        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(10)

            Button:
                text: "Start Crawler"
                on_release: root.start_crawler()

            Button:
                text: "Stop Crawler"
                on_release: root.stop_crawler()

        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(10)

            Button:
                text: "Start Indexer"
                on_release: root.start_indexer()

            Button:
                text: "Stop Indexer"
                on_release: root.stop_indexer()

        Button:
            text: "View Logs"
            size_hint_y: None
            height: dp(50)
            on_release: app.root.current = "logs"

<LogScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(10)
        spacing: dp(10)

        ScrollView:
            do_scroll_x: False

            Label:
                text: root.log_text
                text_size: self.width, None
                size_hint_y: None
                height: self.texture_size[1]

        Button:
            text: "Back"
            size_hint_y: None
            height: dp(50)
            on_release: app.root.current = "home"
